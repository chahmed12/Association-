<%- include('partials/header', { title: 'Accueil' }) %>

<div class="text-center py-12" data-aos="fade-up">
    <h2 class="text-4xl font-bold text-green-800 mb-4 text-gradient animate-float">Bienvenue à l'Association de la Jeunesse de Jeddetta</h2>
    <p class="text-gray-600 max-w-2xl mx-auto">
        Une plateforme dédiée à la jeunesse de notre ville, pour favoriser l'entraide, le sport et la culture.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <!-- Carte 1 -->
        <div class="glass-card p-8 rounded-2xl shimmer border-t-4 border-green-500 shadow-lg" data-aos="zoom-in" data-aos-delay="100">
            <div class="w-16 h-16 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                📝
            </div>
            <h3 class="text-xl font-bold text-green-700 mb-2">Inscriptions</h3>
            <p class="text-sm text-gray-500 mb-6">Rejoignez-nous pour contribuer au développement de Jeddetta.</p>
            <a href="/inscription-hommes.html" class="inline-block bg-green-600 text-white px-8 py-3 rounded-xl hover:bg-green-700 transition transform hover:-translate-y-1 shadow-md">S'inscrire</a>
        </div>
        
        <!-- Carte 2 -->
        <div class="glass-card p-8 rounded-2xl shimmer border-t-4 border-blue-500 shadow-lg" data-aos="zoom-in" data-aos-delay="200">
            <div class="w-16 h-16 bg-blue-100 text-blue-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                📢
            </div>
            <h3 class="text-xl font-bold text-blue-700 mb-2">Nouveautés</h3>
            <p class="text-sm text-gray-500 mb-6">Suivez les dernières activités et événements de l'association.</p>
            <a href="/nouveautes" class="inline-block bg-blue-600 text-white px-8 py-3 rounded-xl hover:bg-blue-700 transition transform hover:-translate-y-1 shadow-md">Voir les actus</a>
        </div>

        <!-- Carte 3 -->
        <div class="glass-card p-8 rounded-2xl shimmer border-t-4 border-amber-500 shadow-lg" data-aos="zoom-in" data-aos-delay="300">
            <div class="w-16 h-16 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                🔐
            </div>
            <h3 class="text-xl font-bold text-amber-700 mb-2">Gestion</h3>
            <p class="text-sm text-gray-500 mb-6">Accès réservé aux administrateurs pour la gestion des membres.</p>
            <a href="/login.html" class="inline-block bg-amber-600 text-white px-8 py-3 rounded-xl hover:bg-amber-700 transition transform hover:-translate-y-1 shadow-md">Administration</a>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
